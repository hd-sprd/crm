{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 30
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/v1/workflow/trigger-internal",
      "schedule": "*/30 * * * *"
    }
  ]
}
